download-dir ~/netshare

preset h @1-month +unread
preset t @1-month +unread +youtube
preset T @1-month +unread -youtube

color audio   #594
color youtube #44c

yt-dlp-program /opt/homebrew/bin/yt-dlp
yt-dlp-arg --no-mtime
alias playlist https://www.youtube.com/feeds/videos.xml?playlist_id={}
alias youtube  https://www.youtube.com/feeds/videos.xml?user={}
alias channel  https://www.youtube.com/feeds/videos.xml?channel_id={}


